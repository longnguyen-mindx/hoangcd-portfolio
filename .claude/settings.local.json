{
  "permissions": {
    "allow": [
      "PowerShell(Get-NetTCPConnection *)",
      "Bash(cmd.exe *)",
      "Bash(npm.cmd run *)",
      "PowerShell(try { $r = Invoke-WebRequest -Uri http://localhost:3000 -UseBasicParsing -TimeoutSec 10; \"HTTP $\\($r.StatusCode\\)\" } catch { \"ERR: $\\($_.Exception.Message\\)\" })",
      "PowerShell(try { $r = Invoke-WebRequest -Uri http://localhost:3000 -UseBasicParsing -TimeoutSec 15; \"HTTP $\\($r.StatusCode\\)\" } catch { \"ERR: $\\($_.Exception.Message\\)\" })",
      "WebFetch(domain:josephcreator.framer.website)",
      "Bash(dir E:dh *)",
      "PowerShell(Start-Process -FilePath npm.cmd -ArgumentList @\\('run','dev','--','-p','3000'\\) -WorkingDirectory 'E:\\\\dh' -WindowStyle Hidden -RedirectStandardOutput 'E:\\\\dh\\\\dev.out.log' -RedirectStandardError 'E:\\\\dh\\\\dev.err.log'; \"started\")",
      "PowerShell(try { $r = Invoke-WebRequest -Uri http://localhost:3000 -UseBasicParsing -TimeoutSec 15; \"status=$\\($r.StatusCode\\) length=$\\($r.Content.Length\\)\" } catch { \"err=$\\($_.Exception.Message\\)\" })",
      "PowerShell(try { $r = Invoke-WebRequest -Uri http://localhost:3000 -UseBasicParsing -TimeoutSec 15; \"status=$\\($r.StatusCode\\)\" } catch { \"err=$\\($_.Exception.Message\\)\" })",
      "Bash(git --version)",
      "Bash(gh --version)",
      "Bash(git init *)",
      "Bash(git config *)",
      "Bash(git -C /e/dh config --global user.email)",
      "Bash(git -C /e/dh config --global user.name)",
      "Bash(git -C /e/dh config user.name \"longnp\")",
      "Bash(git -C /e/dh config user.email \"longnp.contact@gmail.com\")",
      "Bash(git -C /e/dh add -A)",
      "Bash(git -C /e/dh status --short)"
    ]
  }
}
